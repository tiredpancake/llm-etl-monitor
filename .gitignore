# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- MLflow ---
mlflow_data/
mlruns/
mlartifacts/
mlflow.db
mlruns/
*_dump.txt

# --- Data (often large / sensitive - keep raw data out of git) ---
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# --- Generated reports ---
# Per-run files are reproducible and are stored as MLflow artifacts.
reports/*
!reports/.gitkeep
!reports/README.md
!reports/examples/
!reports/examples/**
!reports/final/
!reports/final/**

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Env vars / secrets ---
.env
*.env.local

# --- Jupyter ---
.ipynb_checkpoints/
